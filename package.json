{
  "name": "fixocargo",
  "version": "0.1.0",
  "description": "Boilerplate starter for building a Theta platform theme. Clone, rename, and develop.",
  "files": [
    "dist"
  ],
  "exports": {
    "./assets/*": "./dist/*"
  },
  "scripts": {
    "build": "vite build && yarn test:contract",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:contract": "vitest run test/registration-contract.test.ts",
    "watch": "vite build --watch"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.553.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.0.0",
    "vite": "^7.2.2",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.553.0",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^3.4.0"
  },
  "dependencies": {
    "@radix-ui/react-aspect-ratio": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "blaze-slider": "^1.9.3",
    "tw-animate-css": "^1.4.0"
  }
}
